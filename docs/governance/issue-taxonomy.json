{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "repository": "oaslananka/ssh-mcp-pro",
  "issueTracker": "https://github.com/oaslananka/ssh-mcp-pro/issues",
  "supportPolicy": "../../SUPPORT.md",
  "discussions": {
    "enabled": false,
    "reason": "GitHub Issues is the single source of truth for support, triage, audit findings, and release work."
  },
  "project": {
    "owner": "oaslananka",
    "number": 5,
