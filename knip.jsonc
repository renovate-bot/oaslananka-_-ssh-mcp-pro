{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/index.ts",
    "src/agent-bin.ts",
    "src/render-http.ts",
    "scripts/check-dependency-freshness.mjs",
    "scripts/check-doc-language.mjs",
    "scripts/check-governance.mjs",
    "scripts/check-licenses.mjs",
    "scripts/check-mcp-registry-record.mjs",
    "scripts/check-module-size.mjs",
    "scripts/check-npm-name.mjs",
    "scripts/check-package-contents.mjs",
    "scripts/check-package-install-smoke.mjs",
    "scripts/check-package-scripts.mjs",
    "scripts/check-review-threads.mjs",
    "scripts/check-rulesets.mjs",
    "scripts/docker-ssh-fixture.mjs",
    "scripts/extract-pack-filename.mjs",
    "scripts/generate-sbom.mjs",
    "scripts/lint-commits.mjs",
    "scripts/lint-pr-title.mjs",
    "scripts/release-state.mjs",
    "scripts/run-precommit-hooks.mjs",
    "scripts/run-staged-checks.mjs",
    "scripts/setup-git-hooks.mjs",
    "scripts/sync-version.mjs",
    "scripts/test-pr-title-lint.mjs",
    "scripts/validate-chatgpt-app.mjs",
    "scripts/validate-claude-connector.mjs",
    "scripts/validate-mcp-metadata.mjs",
    "scripts/validate-release-please.mjs",
    "scripts/verify-actions-runtime.mjs",
  ],
  "project": ["src/**/*.ts", "scripts/**/*.mjs", "scripts/lib/*.mjs"],
  "ignoreDependencies": ["reuse"],
  "ignore": ["vitest.mutation.config.ts", "test/"],
  "ignoreBinaries": ["view"],
}
