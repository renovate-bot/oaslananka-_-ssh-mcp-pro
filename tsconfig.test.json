{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "isolatedModules": false,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false
  },
  "include": ["src/**/*", "test/**/*", "vitest.config.ts", "vitest.mutation.config.ts"],
  "exclude": ["node_modules", "dist"]
}
